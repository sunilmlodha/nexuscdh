# NexusCDH — Environment Variables
# Copy this file to .env.local and fill in your values

# ── Supabase (required for database persistence) ──────────────────────────────
# Get from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — bypasses RLS, used by all server-side API routes
# Get from: Supabase → Settings → API → service_role (secret)
# REQUIRED on Vercel — without this, all /api/* routes return 500/503
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Without Supabase ─────────────────────────────────────────────────────────
# The app runs in demo mode — all data stored in browser localStorage.
# Decisions are not persisted to a database.
# The /api/decide endpoint returns 503 with setup instructions.
